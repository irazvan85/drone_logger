# Backend Environment Variables
# Copy this file to .env and fill in the values

# API Configuration
API_TITLE=Drone Photo GPS Visualizer
API_VERSION=0.1.0
API_DESCRIPTION=Web application for visualizing drone photo locations on an interactive map
DEBUG=false

# Database (async driver required)
DATABASE_URL=sqlite+aiosqlite:///./app.db

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:8000"]

# File Upload
MAX_UPLOAD_SIZE=104857600
ALLOWED_EXTENSIONS=jpg,jpeg,png,raw,tiff
UPLOAD_DIR=./uploads

# Restrict photo imports to this directory (recommended for any
# deployment reachable by other users). Unset = no restriction.
# ALLOWED_IMPORT_ROOT=/data/photos

# Logging
LOG_LEVEL=INFO
